# Appwrite Configuration
# Эти переменные уже установлены - НЕ МЕНЯЙТЕ их
NEXT_PUBLIC_APPWRITE_PROJECT_ID="699789ab002d46b8172f"
NEXT_PUBLIC_APPWRITE_PROJECT_NAME="SNT"
NEXT_PUBLIC_APPWRITE_ENDPOINT="https://fra.cloud.appwrite.io/v1"

# Appwrite API Key (создайте в консоли Appwrite -> API Keys)
# Требуется для серверных операций с базой данных
APPWRITE_API_KEY="your-api-key-here"

# Appwrite Database ID (создайте базу данных в консоли Appwrite)
# ID базы данных для коллекций
APPWRITE_DATABASE_ID="snt_database"

# Опционально: ID коллекций (если хотите кастомизировать)
# APPWRITE_USERS_COLLECTION_ID="users"
# APPWRITE_POSTS_COLLECTION_ID="posts"
# APPWRITE_COMMENTS_COLLECTION_ID="comments"
# APPWRITE_LIKES_COLLECTION_ID="likes"
# APPWRITE_SESSIONS_COLLECTION_ID="sessions"
